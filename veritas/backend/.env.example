# ==============================================
# APERTURE PROTOCOL — Backend Configuration
# ==============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Database (PostgreSQL with pgvector extension)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# Server
PORT=3001

# Blockchain (Base Sepolia Testnet)
CHAIN_ID=84532
RPC_URL=https://sepolia.base.org
USDC_CONTRACT_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# Operator Wallet (controls the ApertureVault)
# Generate a fresh wallet for testing. NEVER commit real private keys.
OPERATOR_PRIVATE_KEY=your_operator_private_key_here
OPERATOR_WALLET_ADDRESS=your_operator_wallet_address_here

# Deployed ApertureVault Contract Address
# Deploy your own via: cd contracts && npx hardhat run scripts/deploy.ts --network base-sepolia
APERTURE_VAULT_ADDRESS=your_deployed_vault_address_here

# AI Agent Wallet (used in demo mode for autonomous purchasing)
# Generate via: npm run generate-agent-wallet
AGENT_PRIVATE_KEY=your_agent_private_key_here
AGENT_WALLET_ADDRESS=your_agent_wallet_address_here

# x402 Protocol (Machine-to-Machine Payments)
X402_FACILITATOR_URL=https://x402.org/facilitator
FACT_PRICE_USDC=0.05

# Demo Mode
# Set to "true" to enable demo-specific thresholds and auto-locking
DEMO_MODE=false
